# Godot 4 — generated folders, never commit these
.godot/

# Android build template — large binaries, regenerated by Godot on each machine
**/android/build/

# Export presets — can contain local signing paths
export_presets.cfg

# Release keystore — never commit, back up separately
*.keystore
*.jks

# Android / iOS build artifacts
*.apk
*.aab
*.ipa

# Claude Code local session data
.claude/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor backups
*.bak
*.tmp
