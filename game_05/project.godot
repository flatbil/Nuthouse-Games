; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="AI Slop Slots"
config/description="Nuthouse Games — AI-generated chaos casino"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Mobile")

[autoload]

GameConfig="*res://config/GameConfig.gd"
EventBus="*res://autoloads/EventBus.gd"
SaveManager="*res://autoloads/SaveManager.gd"
GameManager="*res://autoloads/GameManager.gd"
Settings="*res://autoloads/Settings.gd"
SceneTransition="*res://autoloads/SceneTransition.gd"
Toast="*res://autoloads/Toast.gd"
UIFactory="*res://autoloads/UIFactory.gd"

[display]

window/size/viewport_width=844
window/size/viewport_height=390
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=0

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
